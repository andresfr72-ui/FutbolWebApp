38341>>>>>>>    Procedure SetActionButtons
38344>>>>>>>        tWebNavigateData NavigateData
38344>>>>>>>        tWebNavigateData NavigateData
38344>>>>>>>        Boolean bHasRecord
38344>>>>>>>        Handle hoDD
38344>>>>>>>
38344>>>>>>>        Get Server to hoDD
38345>>>>>>>        Get GetNavigateData to NavigateData
38346>>>>>>>        Get HasRecord of hoDD to bHasRecord
38347>>>>>>>
38347>>>>>>>        // let's hide all buttons and then Show the ones we want
38347>>>>>>>        WebSet pbRender of oEditBtn to False
38348>>>>>>>        WebSet pbRender of oSaveBtn to False
38349>>>>>>>        WebSet pbRender of oCancelChangesBtn to False
38350>>>>>>>        WebSet pbRender of oDeleteBtn to False
38351>>>>>>>
38351>>>>>>>        If (NavigateData.bReadOnly) Begin
38353>>>>>>>            WebSet pbRender of oEditBtn to True
38354>>>>>>>        End
38354>>>>>>>>
38354>>>>>>>        Else Begin
38355>>>>>>>            WebSet pbRender of oSaveBtn to True
38356>>>>>>>            WebSet pbRender of oCancelChangesBtn to True
38357>>>>>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38358>>>>>>>        End
38358>>>>>>>>
38358>>>>>>>    End_Procedure
38359>>>>>>>
