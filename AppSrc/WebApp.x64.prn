37496>>>>>>>        Case Begin
37496>>>>>>>            Case (NavigateData.eNavigateType = nfFromMain)
37498>>>>>>>                // If from main, this is a propbably a main file Select to Zoom.
37498>>>>>>>                Case Break
37499>>>>>>>
37499>>>>>>>            Case (NavigateData.eNavigateType = nfFromParent)
37502>>>>>>>                // If from parent, this is a constrained drill down.
37502>>>>>>>                Case Break
37503>>>>>>>
37503>>>>>>>            Case (NavigateData.eNavigateType = nfFromChild)
37506>>>>>>>                // If from child, this is a probably a parent Zoom from a Zoom.
37506>>>>>>>                Case Break
37507>>>>>>>
37507>>>>>>>            Case Else // must be nfUndefined
37507>>>>>>>
37507>>>>>>>        Case End
37507>>>>>>>
37507>>>>>>>        Send SetActionButtons
37508>>>>>>>
