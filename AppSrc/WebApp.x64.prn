38372>>>>>>>        Case Begin
38372>>>>>>>            Case (NavigateData.eNavigateType = nfFromMain)
38374>>>>>>>                // If from main, this is a propbably a main file Select to Zoom.
38374>>>>>>>                Case Break
38375>>>>>>>
38375>>>>>>>            Case (NavigateData.eNavigateType = nfFromParent)
38378>>>>>>>                // If from parent, this is a constrained drill down.
38378>>>>>>>                Case Break
38379>>>>>>>
38379>>>>>>>            Case (NavigateData.eNavigateType = nfFromChild)
38382>>>>>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38382>>>>>>>                Case Break
38383>>>>>>>
38383>>>>>>>            Case Else // must be nfUndefined
38383>>>>>>>
38383>>>>>>>        Case End
38383>>>>>>>
38383>>>>>>>        Send SetActionButtons
38384>>>>>>>
38384>>>>>>>    End_Procedure
38385>>>>>>>
38385>>>>>>>End_Object 
